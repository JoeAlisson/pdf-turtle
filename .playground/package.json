{
  "name": "pdf-turtle-playground",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf ./app/swagger-client/**",
    "generate-openapi-client": "node ./swagger/codegen.js",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "**/*.{js,ts,vue}": [
      "npx prettier --write",
      "npx eslint --fix"
    ]
  },
  "dependencies": {
    "@quasar/extras": "^1.18.0",
    "axios": "^1.16.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "monaco-editor": "^0.55.1",
    "quasar": "^2.19.3",
    "uuid": "^14.0.0",
    "vue": "^3.4.21",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@quasar/vite-plugin": "^1.11.0",
    "@types/file-saver": "^2.0.7",
    "@types/json-schema": "^7.0.15",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "sass-loader": "^17.0.0",
    "swagger-axios-codegen": "^0.18.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.1"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "^3.4.5"
    }
  }
}
